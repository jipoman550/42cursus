NAME        = convert

CXX         = c++
CXXFLAGS    = -Wall -Wextra -Werror -std=c++98

SRCS        = main.cpp \
              ScalarConverter.cpp

OBJS        = $(SRCS:.cpp=.o)
INCS        = ScalarConverter.hpp

# 터미널 출력용 색상 정의
GREEN       = \033[0;32m
RED         = \033[0;31m
YELLOW      = \033[0;33m
CYAN        = \033[0;36m
RESET       = \033[0m

all: $(NAME)

$(NAME): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $(NAME) $(OBJS)

%.o: %.cpp $(INCS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS)

fclean: clean
	rm -f $(NAME)

re: fclean all

# =========================================================================
# 🚀 자동화 테스트 시스템 (make test)
# =========================================================================
test: $(NAME)
	@echo "$(CYAN)==================================================$(RESET)"
	@echo "$(CYAN)       STARTING SCALAR CONVERTER AUTOMATED TEST   $(RESET)"
	@echo "$(CYAN)==================================================$(RESET)"
	@echo ""
	@# -----------------------------------------------------------------
	@# [그룹 1] 기본 정상 데이터
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 1] Basic Normal Data$(RESET)"
	@./$(NAME) c
	@echo "--------------------------------------------------"
	@./$(NAME) 0
	@echo "--------------------------------------------------"
	@./$(NAME) 42
	@echo "--------------------------------------------------"
	@./$(NAME) 42.42f
	@echo "--------------------------------------------------"
	@./$(NAME) 4.2
	@echo "============="
	@# -----------------------------------------------------------------
	@# [그룹 2] 문자(char) 경계값 및 출력 여부
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 2] Char Bounds & Displayability$(RESET)"
	@./$(NAME) 65
	@echo "--------------------------------------------------"
	@./$(NAME) 31
	@echo "--------------------------------------------------"
	@./$(NAME) 127
	@echo "--------------------------------------------------"
	@./$(NAME) 128
	@echo "--------------------------------------------------"
	@./$(NAME) -10
	@echo "============="
	@# -----------------------------------------------------------------
	@# [그룹 3] 정수(int) 오버플로우 / 언더플로우
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 3] Int Overflow & Underflow$(RESET)"
	@./$(NAME) 2147483647
	@echo "--------------------------------------------------"
	@./$(NAME) -2147483648
	@echo "--------------------------------------------------"
	@./$(NAME) 2147483649
	@echo "--------------------------------------------------"
	@./$(NAME) -2147483649
	@echo "============="
	@# -----------------------------------------------------------------
	@# [그룹 4] 실수 정밀도 및 거대 오버플로우
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 4] Float/Double Precision & Huge Overflow$(RESET)"
	@./$(NAME) 4294967295
	@echo "--------------------------------------------------"
	@./$(NAME) 1e30
	@echo "--------------------------------------------------"
	@./$(NAME) 1e40
	@echo "--------------------------------------------------"
	@./$(NAME) 1e310
	@echo "============="
	@# -----------------------------------------------------------------
	@# [그룹 5] 의사 리터럴 (Pseudo Literals)
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 5] Pseudo Literals (Special Cases)$(RESET)"
	@./$(NAME) nan
	@echo "--------------------------------------------------"
	@./$(NAME) nanf
	@echo "--------------------------------------------------"
	@./$(NAME) +inf
	@echo "--------------------------------------------------"
	@./$(NAME) -inff
	@echo "============="
	@# -----------------------------------------------------------------
	@# [그룹 6] 예외/잘못된 형식 (INVALID)
	@# -----------------------------------------------------------------
	@echo "$(YELLOW)[GROUP 6] Invalid Input Handling$(RESET)"
	@./$(NAME) abc
	@echo "--------------------------------------------------"
	@./$(NAME) 42.42ff
	@echo "--------------------------------------------------"
	@./$(NAME) +
	@echo "--------------------------------------------------"
	@./$(NAME) 1.2.3
	@echo "$(CYAN)==================================================$(RESET)"
	@echo "$(GREEN)             ALL TEST CASES EXECUTED              $(RESET)"
	@echo "$(CYAN)==================================================$(RESET)"

.PHONY: all clean fclean re test